generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserMemories {
  id        String       @id @default(cuid())
  userId    String       @unique
  createdAt DateTime     @default(now())
  memories  MemoryItem[]
}

model MemoryItem {
  id          String   @id @default(cuid())
  imageUrl    String
  description String
  title       String?
  date        DateTime

  userMemoriesId String
  userMemories   UserMemories @relation(fields: [userMemoriesId], references: [id], onDelete: Cascade)
}

